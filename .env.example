# === Обязательные ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=123456789

# Шифрование токенов Метрики (32+ символов, любая строка)
ACCESS_TOKEN_ENCRYPTION_KEY=your_secret_key_32_chars_minimum

# === Трекинг-сервер ===
# Публичный URL, по которому доступен ваш сервер (без trailing /)
TRACKING_BASE_URL=https://go.example.com
TRACKING_WEB_PORT=8080

# === Яндекс Метрика (глобальные настройки, fallback) ===
# Можно не задавать, если настраиваете per-channel через бота
YANDEX_METRIKA_COUNTER_ID=
YANDEX_METRIKA_MP_TOKEN=

# === MAX (опционально) ===
MAX_BOT_TOKEN=
MAX_AUTO_CONNECT_ENABLED=false

# === Тюнинг (необязательно) ===
# TRACKING_INVITE_LINK_EXPIRE_SECONDS=3600
# TRACKING_CONVERSION_DELAY_SECONDS=420
# TRACKING_CLEANUP_MAX_AGE_HOURS=24
# TRACKING_POOL_SIZE_PER_CHANNEL=5
# TRACKING_POOL_REPLENISH_INTERVAL_SECONDS=300
# TRACKING_MAX_MATCH_WINDOW_MINUTES=15
# TRACKING_METRIKA_GOAL_NAME=channel_subscription
# TRACKING_MAX_METRIKA_GOAL_NAME=max_channel_subscription
# LOG_LEVEL=INFO
# TIMEZONE=Europe/Moscow
# DB_PATH=data/bot_database.db
